# NULL ZTNA Platform Environment Configuration
NODE_ENV=development
PORT=5000

# Security Configuration
JWT_SECRET=super_secret_jwt_sign_key_change_in_production
TOTP_ISSUER=NULL-ZTNA

# Seed Administrator Credentials
ADMIN_NAME=System Administrator
ADMIN_EMAIL=admin@null.local
ADMIN_PASSWORD=AdminPass123!

# PostgreSQL Database Configuration
# If connection fails, backend will run in in-memory Mock Mode
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=null_ztna
# Alternatively, use a connection URI:
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/null_ztna
